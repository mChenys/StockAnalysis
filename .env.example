# 应用配置
NODE_ENV=development
PORT=3000

# 数据库配置（可选，不配置将使用内存存储）
MONGODB_URI=mongodb://localhost:27017/stock_analysis
REDIS_URL=redis://localhost:6379

# AI模型API密钥（在Web界面配置或这里预设）
DEFAULT_OPENAI_API_KEY=sk-your_openai_api_key_here
DEFAULT_CLAUDE_API_KEY=your_claude_api_key_here  
DEFAULT_GEMINI_API_KEY=your_gemini_api_key_here
DEFAULT_ZHIPU_API_KEY=your_zhipu_api_key_here

# 微信推送配置
# 方式1：Server酱（推荐，最简单）https://sct.ftqq.com/
SERVERCHAN_KEY=SCT123456789abcdef

# 方式2：企业微信
WECHAT_CORP_ID=your_corp_id
WECHAT_CORP_SECRET=your_corp_secret
WECHAT_AGENT_ID=your_agent_id

# 方式3：微信测试号
WECHAT_TEST_APPID=your_test_appid
WECHAT_TEST_APPSECRET=your_test_appsecret
WECHAT_TEMPLATE_ID=your_template_id
WECHAT_OPEN_ID=your_open_id

# 股票数据源API密钥（可选，不配置将使用免费源）
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
FINNHUB_API_KEY=your_finnhub_key
POLYGON_API_KEY=your_polygon_key

# 日志配置
LOG_LEVEL=info

# 安全配置
JWT_SECRET=your_jwt_secret_here_change_in_production
BCRYPT_ROUNDS=10

# 系统配置
MAX_ANALYSIS_HISTORY=1000
CACHE_TIMEOUT=300000
API_RATE_LIMIT=100
